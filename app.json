{
  "expo": {
    "name": "Hearts Score Tracker",
    "slug": "hearts-score-tracker",
    "scheme": "hearts-score-tracker",
    "version": "1.1.1",
    "splash": {
      "backgroundColor": "#000000",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.cybergoose.heartsscoretracker",
      "buildNumber": "6",
      "appStoreUrl": "https://apps.apple.com/app/hearts-score-tracker/id6755978632",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.cybergoose.heartsscoretracker",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=org.cybergoose.heartsscoretracker",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      }
    },
    "newArchEnabled": true,
    "plugins": [
      "expo-font",
      [
        "react-native-iap",
        {
          "ios": {
            "enableStoreKit2": true
          },
          "android": {
            "store": "play"
          }
        }
      ],
      "expo-router"
    ],
    "icon": "./assets/images/icon.png",
    "owner": "ernkerr",
    "extra": {
      "eas": {
        "projectId": "0ebbd0c1-d9af-4a55-a820-39a496e98359"
      }
    }
  }
}
